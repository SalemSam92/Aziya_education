{% block style %}
	<link rel="stylesheet" href="css/modal.css">
{% endblock %}

{% block main %}

	<div class="box">

		<h2>Ajouter une classe</h2>

		<form class="form-modal" action="/dashboardDirector/{{user.school_id}}/createClassroom" method="POST">

			<label for="name">Nom de la classe </label>
			<input type="text" id="name" name="name" placeholder="CM2 A" autofocus>

			<label for="nbMaxStudent">Nombre d'élève maximun</label>
			<input type="text" id="nbMaxStudent" name="nbMaxStudent" placeholder="25">

			<button type="submit" id="add">Ajouter</button>
		</form>
		<button type="submit" id="close-modal-classroom">Fermer</button>

		{% if error %}
			<div class="messError">
				{{error}}
			</div>
		{% endif %}


	</div>

{% endblock %}

{% block footer %}{% endblock %}