{% block style %}
	<link rel="stylesheet" href="css/modal.css">
{% endblock %}

{% block main %}

	<div class="box">

		<h2>Ajouter un professeur</h2>

		<form class="form-modal" action="/dashboardDirector/{{user.school_id}}/createProfessor " method="POST">

			<label for="lastname">Nom</label>
			<input type="text" id="lastname" name="lastname" placeholder="Dupont" autofocus>

			<label for="firstname">Prénom</label>
			<input type="text" id="firstname" name="firstname" placeholder="Jean">

			<label for="mail">E-mail</label>
			<input type="mail" id="mail" name="mail" placeholder="dupont@gmail.com">

			<label for="password">Mot de passe</label>
			<input type="password" id="password" name="password" placeholder="********">

			<button type="submit" id="add">Ajouter</button>
		</form>
		<button type="submit" id="close-modal-professor">Fermer</button>

		{% if error %}
			<div class="messError">
				{{error}}
			</div>
		{% endif %}


	</div>

{% endblock %}

{% block footer %}{% endblock %}
